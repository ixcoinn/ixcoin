# ============================================================
# IXCoin AI Layer — Environment Variables
# Copy to .env and fill in your values
# ============================================================

# ── SERVER ───────────────────────────────────────────────────
PORT=3000
NODE_ENV=production
LOG_LEVEL=info

# ── DATABASE (optional — node runs in local mode without it) ─
DATABASE_URL=postgresql://user:password@localhost:5432/ixcoin

# ── SECURITY ─────────────────────────────────────────────────
# REQUIRED: Change to a random 32+ character string
SESSION_SECRET=change-this-to-a-random-secret-min-32-chars

# Comma-separated allowed origins for CORS (* = allow all, not recommended for prod)
ALLOWED_ORIGINS=*

# ── P2P NETWORK ──────────────────────────────────────────────
NODE_TYPE=AI_NODE
P2P_PORT=9080

# Auto-generated if empty — set a fixed ID for persistent nodes
NODE_ID=

# Comma-separated list of initial peer WebSocket addresses
# Example: ws://peer1.example.com:9080,ws://peer2.example.com:9080
INITIAL_PEERS=
