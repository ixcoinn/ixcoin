# IXCoin P2P AI Network — Environment Variables
# Salin ke .env dan isi nilai yang sesuai

PORT=8080
DATABASE_URL=postgresql://user:password@localhost:5432/ixcoin
SESSION_SECRET=ganti-dengan-random-secret-32-karakter

# P2P Node Configuration
NODE_TYPE=AI_NODE
P2P_PORT=9080
NODE_ID=

# Daftar initial peers (pisah koma)
# Format: ws://ip-vps:9080,ws://ip-vps2:9081
INITIAL_PEERS=
