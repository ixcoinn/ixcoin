# Database
DATABASE_URL=postgresql://user:password@localhost:5432/ixcoin

# Session
SESSION_SECRET=change-this-to-a-long-random-secret

# IXCoin Node RPC (optional — omit to run in simulation mode)
IXCOIN_RPC_URL=http://localhost:8332
IXCOIN_RPC_USER=ixcoinrpc
IXCOIN_RPC_PASS=your_rpc_password

# AI Life Layer
AI_POLL_INTERVAL_MS=30000
